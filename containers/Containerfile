FROM docker.io/denoland/deno:latest AS builder

# Install Node.js (needed for deno task build which runs vite build)
RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates \
    && curl -fsSL https://deb.nodesource.com/setup_lts.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /build

# Copy application source code
ADD . .

RUN deno i
RUN deno task build

FROM node:lts-slim
WORKDIR /app

# Install Caddy and dependencies for HTTPS
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    gnupg \
    debian-keyring \
    debian-archive-keyring \
    apt-transport-https \
    && curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' | gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg \
    && curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' | tee /etc/apt/sources.list.d/caddy-stable.list \
    && apt-get update && apt-get install -y --no-install-recommends caddy \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/build ./build
COPY --from=builder /build/node_modules ./node_modules

COPY containers/start.sh /app/start.sh
RUN chmod +x /app/start.sh

# Create non-root user
RUN useradd -l -u 10001 -s /sbin/nologin -M appuser

EXPOSE 8443 3000

USER appuser
CMD ["/app/start.sh"]